# Firebase cloud-sync config (optional). Copy this file to `.env` and fill in
# the six values from Firebase console → Project settings → Your apps → Config.
# These override the `direct` values in src/lib/firebaseConfig.js.
#
# The apiKey is a PUBLIC client identifier — safe to expose in the built app.
# Security is enforced by firestore.rules, not by hiding this.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
